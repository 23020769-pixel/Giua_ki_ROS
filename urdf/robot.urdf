<?xml version="1.0"?>
<robot name="robot">

  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.035" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-9.9541E-05 0 -0.0068351" rpy="0 0 0" />
      <mass value="0.18913" />
      <inertia ixx="0.00010688" ixy="0" ixz="2.0217E-07" iyy="9.6933E-05" iyz="0" izz="0.00017249" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot_pkg/meshes/base_link.STL" />
      </geometry>
      <material name="green">
        <color rgba="0 0.51373 0.11373 1" />
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot_pkg/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <link name="wheel_right">
    <inertial>
      <mass value="0.029068" />
      <inertia ixx="5.2341E-06" ixy="0" ixz="0" iyy="9.3781E-06" iyz="0" izz="5.2341E-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot_pkg/meshes/wheel_right.STL" />
      </geometry>
      <material name="yellow"><color rgba="1 1 0 1" /></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot_pkg/meshes/wheel_right.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="wheel_right_joint" type="continuous">
    <origin xyz="0.0011238 -0.0525 -0.0125" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="wheel_right" />
    <axis xyz="0 1 0" />
  </joint>
  <gazebo reference="wheel_right">
    <material>Gazebo/Yellow</material>
    <mu1 value="1.0"/><mu2 value="1.0"/>
  </gazebo>

  <link name="wheel_left">
    <inertial>
      <mass value="0.029068" />
      <inertia ixx="5.2341E-06" ixy="0" ixz="0" iyy="9.3781E-06" iyz="0" izz="5.2341E-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot_pkg/meshes/wheel_left.STL" />
      </geometry>
      <material name="yellow"><color rgba="1 1 0 1" /></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot_pkg/meshes/wheel_left.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="wheel_left_joint" type="continuous">
    <origin xyz="0.0011238 0.0525 -0.0125" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="wheel_left" />
    <axis xyz="0 1 0" />
  </joint>
  <gazebo reference="wheel_left">
    <material>Gazebo/Yellow</material>
    <mu1 value="1.0"/><mu2 value="1.0"/>
  </gazebo>

  <gazebo reference="o_wheel_1">
    <material>Gazebo/Grey</material>
    <mu1 value="0.001"/><mu2 value="0.001"/>
  </gazebo>
  <gazebo reference="o_wheel_2">
    <material>Gazebo/Grey</material>
    <mu1 value="0.001"/><mu2 value="0.001"/>
  </gazebo>

  <link name="o_wheel_2">
    <inertial>
      <origin xyz="0 0 -0.0054375" rpy="0 0 0" /><mass value="0.045334" />
      <inertia ixx="2.4722E-06" ixy="0" ixz="0" iyy="2.4722E-06" iyz="0" izz="3.8126E-06" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://my_robot_pkg/meshes/o_wheel_2.STL" /></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://my_robot_pkg/meshes/o_wheel_2.STL" /></geometry>
    </collision>
  </link>
  <joint name="o_wheel_2_point" type="fixed">
    <origin xyz="0.026124 0 -0.023" rpy="0 0 0" />
    <parent link="base_link" /><child link="o_wheel_2" />
  </joint>

  <link name="o_wheel_1">
    <inertial>
      <origin xyz="0 0 -0.0054375" rpy="0 0 0" /><mass value="0.045334" />
      <inertia ixx="2.4722E-06" ixy="0" ixz="0" iyy="2.4722E-06" iyz="0" izz="3.8126E-06" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://my_robot_pkg/meshes/o_wheel_1.STL" /></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://my_robot_pkg/meshes/o_wheel_1.STL" /></geometry>
    </collision>
  </link>
  <joint name="o_wheel_1_point" type="fixed">
    <origin xyz="-0.023876 0 -0.023" rpy="0 0 0" />
    <parent link="base_link" /><child link="o_wheel_1" />
  </joint>

  <link name="link1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" /><mass value="0.1" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="7.4184E-06" iyz="0" izz="2.799E-06" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://my_robot_pkg/meshes/link1.STL" /></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://my_robot_pkg/meshes/link1.STL" /></geometry>
    </collision>
  </link>
  <joint name="link1_joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" /><child link="link1" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.06" effort="1000" velocity="10.0" />
  </joint>
  <gazebo reference="link1">
    <material>Gazebo/Yellow</material>
    <mu1 value="1.0"/><mu2 value="1.0"/>
    <turnGravityOff>true</turnGravityOff>
  </gazebo>

  <link name="link2">
    <inertial>
      <origin xyz="-0.027746 0 0" rpy="0 0 0" /><mass value="0.1" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="3.5422E-06" iyz="0" izz="3.7809E-06" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://my_robot_pkg/meshes/link2.STL" /></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://my_robot_pkg/meshes/link2.STL" /></geometry>
    </collision>
  </link>
  <joint name="link2_joint" type="revolute">
    <origin xyz="0 0 0.0685" rpy="0 0 0" />
    <parent link="link1" /><child link="link2" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14" upper="3.14" effort="1000" velocity="10.0" />
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <gazebo reference="link2">
    <material>Gazebo/Yellow</material>
    <mu1 value="1.0"/><mu2 value="1.0"/>
  </gazebo>

  <link name="lidar">
    <inertial>
      <origin xyz="0 0 -0.0034679" rpy="0 0 0" /><mass value="0.020473" />
      <inertia ixx="7.1298E-07" ixy="0" ixz="0" iyy="7.1298E-07" iyz="0" izz="1.1231E-06" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://my_robot_pkg/meshes/lidar.STL" /></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://my_robot_pkg/meshes/lidar.STL" /></geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.031124 0 0.0045" rpy="0 0 0" />
    <parent link="base_link" /><child link="lidar" />
  </joint>
  <gazebo reference="lidar">
    <material>Gazebo/Red</material>
    <mu1 value="1.0"/><mu2 value="1.0"/>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.105</wheel_separation>
      <wheel_diameter>0.025</wheel_diameter>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros><remapping>~/out:=joint_states</remapping></ros>
      <update_rate>30</update_rate>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
      <joint_name>link1_joint</joint_name>
      <joint_name>link2_joint</joint_name>
    </plugin>

    <plugin name="gazebo_ros_joint_pose_trajectory" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <remapping>set_joint_trajectory:=/set_joint_trajectory</remapping>
      </ros>
      <update_rate>20</update_rate>
      <frame_id>base_footprint</frame_id>
      <joint_name>link1_joint</joint_name>
      <joint_name>link2_joint</joint_name>
    </plugin>
  </gazebo>
  <gazebo reference="lidar">
    <sensor name="lidar" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize> <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <argument>~/out:=scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
</robot>